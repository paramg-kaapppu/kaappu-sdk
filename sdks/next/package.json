{
  "name": "@kaappu/next",
  "version": "0.1.0",
  "description": "Kaappu Identity — Next.js edge pipeline, server-side helpers, and route guards",
  "keywords": ["kaappu", "auth", "nextjs", "middleware"],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "types": "./dist/server.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kaappu/core": "file:../core",
    "jose": "^5.2.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "next": "^14.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
